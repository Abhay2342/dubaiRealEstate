    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "salesArea",
      "value": "DUBAI MARINA",
      "type": "string",
      "description": "Area name used in /api/sales/averages/{area}. Change to a real area from your DB."
    },
    {
      "key": "rentsArea",
      "value": "DUBAI MARINA",
      "type": "string",
      "description": "Area name used in /api/rents/averages/{area}. Change to a real area from your DB."
